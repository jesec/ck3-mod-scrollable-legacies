Structure:

# Story cycle type
key = {
	# Effect is executed when story just has been created
	# root - active story cycle
	# scope:story - same as root
	on_setup = {}

	# Effect is executed when story is ended by end_story effect
	# root - active story cycle
	# scope:story - same as root
	on_end = {}

	# Effect is executed when story owner dies. It's a good time to set new story owner
	# root - active story cycle
	# scope:story - same as root
	on_owner_death = {}

	# Boolean determines whether this type of story cycle is displayed in the interface
	# default: no
	#
	visible = no

	# Set an icon for the Story Cycle
	# Can be repeated with optional triggers. First valid chosen.
	#
	icon = {

		# Optional trigger. scope:story is the story cycle
		#
		trigger = {}

		# File path to desired asset
		# If no icon is defined, the game will by default try to find an icon in
		# "gfx/interface/icons/story_cycles/" with the same name as the story cycle
		#
		reference = "gfx/interface/icons/story_cycles/story_icon_mystical_creature.dds"
	}

	# Set a background for the Story Cycle
	# Can be repeated with optional triggers. First valid chosen.
	#
	background = {

		# Optional trigger. scope:story is the story cycle
		#
		trigger = {}

		# File path to desired asset
		# If no background is defined, the default will be shown.
		# Default background path defined in 00_graphics.txt under
		# STORY_CYCLE_TYPE_FALLBACK_BACKGROUND
		#
		reference = "gfx/interface/illustrations/event_scenes/corridor_day.dds"
	}

	# Specific script variables to be used for visualization.
	#
	visualization = {

		# These display one or multiple things fetched from a variable saved
		# on the story cycle scope.
		# They're all defined with the variable name and an optional label
		# that's displayed in the UI.
		# If the specified variable name does not correspond to the type,
		# it will not be displayed and throw an error.
		#
		character = {
			variable_name = "cool_dude_1"
			label = "COOL_DUDE"
		}
		character_list = {
			variable_name = "list_of_cool_dudes"
			label = "COOL_DUDES"
		}
		title = {...}
		title_list = {...}
		artifact = {...}
		artifact_list = {...}

		# Loc key for a string that will be shown in the UI.
		# If omitted, nothing will be displayed.
		# Has "STORY" as an available scope.
		#
		custom_string_key = "LOC_KEY"

		# Visualizations for counters
		#
		basic_counter = {
			variable_name = "some_value_variable"
			min = 0
			max = 10
			label = "MY_COOL_VALUE"
			min_label = "MIN_VALUE_LABEL"
			max_label = "MAX_VALUE_LABEL"
		}
		tug_of_war_counter = {
			variable_name = "some_value_variable"
			min = -10
			max = 10
			label = "MY_COOL_VALUE"
			min_label = "MIN_VALUE_LABEL"
			max_label = "MAX_VALUE_LABEL"
		}

		# List of decisions, modifiers, and traits to be displayed
		#
		decisions = { decision_1 decision_2 }
		modifiers = { modifier_1 modifier_2 }
		traits = { trait_1 trait_2 }
	}

	# Any number of effect groups can be defined for story cycle type
	effect_group = {

		# Duration between attempts to execute this effect group . Can be fixed value or picked randomly from a range
		days/weeks/months/years = <int>/{<int>..<int>}

		# Chance that effect group will fire in the interval [0..100]
		# It chance doesn't proc, another attempt will be made again on next duration tick
		# If no chance is specified, effect group is always triggered
		chance = <fixed_point>

		# Effect group will fire only if trigger is satisfied
		# root - active story cycle
		# scope:story - same as root
		trigger = {}

		# Execute effect only if trigger is valid
		# Only one independent triggered_effect can be defined
		# root - active story cycle
		# scope:story - same as root
		triggered_effect = {
			trigger = {}
			effect = {}
		}

		# Execute at most one valid triggered effect picked at random
		# Any number of triggered_effect can be put inside random_valid block
		# root - active story cycle
		# scope:story - same as root
		random_valid = {
			triggered_effect = {}
			...
			triggered_effect = {}
		}

		# Execute at most one first valid triggered effect
		# Any number of triggered_effect can be put inside first_valid block
		# root - active story cycle
		# scope:story - same as root
		first_valid = {
			triggered_effect = {}
			...
			triggered_effect = {}
		}

		# Effect is only executed if none of the triggered effect were fired before
		# root - active story cycle
		# scope:story - same as root
		fallback = {}
	}
	...
	effect_group = {}
}
