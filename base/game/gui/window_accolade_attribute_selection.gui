#######################################################################
################# ACCOLADE ATTRIBUTE SELECTION VIEW ###################
#######################################################################

window = {
	name = "accolade_attribute_selection_view"
	size = { 540 780 }
	parentanchor = top|right
	position = { -630 170 }
	layer = middle

	using = Window_Background_Subwindow

	state = {
		name = _show
		using = Animation_FadeIn_Quick

		position = { -630 170 }
	}

	state = {
		name = _hide
		using = Animation_FadeOut_Quick

		position_x = -570
	}

	vbox = {
		datacontext = "[AccoladeAttributeSelectionView.GetAccolade]"

		margin = { 5 5 }

		header_pattern = {
			layoutpolicy_horizontal = expanding

			blockoverride "header_text"
			{
				text = "[Accolade.GetNameNoTooltip]"
			}

			blockoverride "button_close"
			{
				texture = "gfx/interface/icons/flat_icons/window_close.dds"

				onclick = "[AccoladeAttributeSelectionView.Close]"

				tooltip = "CLOSE_TOOLTIP"
			}
		}

		scrollbox = {
			name = "attributes_scrollbox"
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding
			size = { 0 120 }

			blockoverride "scrollbox_margins"
			{
				using = Scrollbox_Margins
				margin_top = 40
			}

			blockoverride "scrollbox_content"
			{
				fixedgridbox = {
					name = "types_grid"
					datamodel = "[AccoladeAttributeSelectionView.GetOtherAttributes]"
					layoutpolicy_horizontal = expanding
					flipdirection = yes
					datamodel_wrap = 3
					addcolumn = 180
					addrow = 164

					item = {
						widget = {
							size = { 140 150 }

							button_standard = {
								name = "select"
								size = { 96 120 }
								parentanchor = top|hcenter

								enabled = "[StringIsEmpty( AccoladeType.GetKnightValidForAccoladeTypeDesc(Accolade.Self ) ) ]"
								onclick = "[AccoladeAttributeSelectionView.OnClick( AccoladeType.Self )]"
								down = "[ObjectsEqual( AccoladeType.Self, AccoladeAttributeSelectionView.GetSelectedType )]"

								datacontext = "[AccoladeType]"
								tooltipwidget = {
									object_tooltip_pop_out = {
										blockoverride "title_text" {
											margin = { 0 8 }
											text = "[AccoladeType.GetName]"
											default_format = "#T"
										}
										blockoverride "concept_link" {
											text = "[accolade_type|E]"
										}
										blockoverride "description_text" {
											text = "ACCOLADE_TYPE_TT"
										}
									}
								}
								tooltip_when_disabled = "ACCOLADE_TYPE_DISABLED"

								highlight_icon = {
									name = "accolade_type_icon"
									parentanchor = center
									size = { 92	116 }
									texture = "[AccoladeType.GetIcon]"
									using = Mask_Rough_Edges
								}

								selection_glow = {
									visible = "[ObjectsEqual( AccoladeType.Self, AccoladeAttributeSelectionView.GetSelectedType )]"
								}
							}

							text_label_center = {
								name = "accolade_type_name"
								parentanchor = bottom|hcenter
								layoutpolicy_horizontal = expanding

								text = "[AccoladeType.GetNameNoTooltip]"
								align = center
								default_format = "#high"
								max_width = 150
							}
						}
					}
				}
			}
		}

		hbox = {
			margin = { 10 15 }
			spacing = 10

			button_standard = {
				name = "close_button"
				size = { 200 40 }
				text = "CLOSE_LABEL"
				tooltip = "CLOSE_TOOLTIP"
				onclick = "[AccoladeAttributeSelectionView.Close]"
			}

			button_standard = {
				name = "confirm_button"
				size = { 200 40 }
				datacontext = "[AccoladeAttributeSelectionView.GetSelectedType]"
				tooltip = "ACCOLADE_ATTRIBUTE_SELECTION_CONFIRM_TT"
				tooltip_when_disabled = "ACCOLADE_ATTRIBUTE_SELECTION_DISABLED_TT"
				text = "ACCOLADE_ATTRIBUTE_SELECTION_CONFIRM"
				onclick = "[AccoladeAttributeSelectionView.ConfirmSelection]"
				enabled = "[IsValidCommand( Accolade.MakeAddAccoladeTypeCommand( AccoladeAttributeSelectionView.GetSelectedType ) )]"
			}
		}
	}
}

