window = {
	name = "window_situation_list"
	widgetid = "window_situation_list"
	layer = windows_layer
	parentanchor = top|right
	movable = no
	allow_outside = yes

	using = Window_Size_MainTab

	oncreate = "[BindTabsContext]"
	oncreate = "[PdxGuiTabs.AddTab( 'your' )]"
	oncreate = "[PdxGuiTabs.AddTab( 'other' )]"

	state = {
		name = _show
		using = Animation_FadeIn_Quick
		using = Sound_WindowShow_Standard
		using = Window_Position_MainTab

		on_start = "[GetVariableSystem.Set( 'situations_tab', 'situations'  )]"
	}

	margin_widget = {
		size = { 100% 100% }
		margin_top = 30
		margin_bottom = 28
		margin_right = 13

		widget = {
			size = { 100% 100% }

			vbox = {
				using = Window_Margins

				header_pattern = {
					layoutpolicy_horizontal = expanding

					blockoverride "header_text"
					{
						text = "SITUATION_LIST_WINDOW_HEADER"
					}

					blockoverride "button_close"
					{
						onclick = "[SituationListWindow.Close]"
					}
				}

				situation_tabs = {}

				vbox = {
					name = "situation_desc"
					layoutpolicy_horizontal = expanding
					margin_bottom = 10

					text_single = {
						autoresize = yes
						maximumsize = { 450 -1 }

						text = "SITUATION_LIST_WINDOW_HEADER_DESC"
						default_format = "#weak"
						align = center
					}
				}

				vbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding

					hbox_tab_buttons = {
	
						blockoverride "tab_name"
						{
							text = "[PdxGuiTabItem.LocalizeTab( 'situation_tab' )]"
							default_format = "#clickable"
							using = SubTabShortcut
						}
					}

					vbox = {
						name = "situations_content"

						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding

						scrollbox = {
							using = Animation_Tab_Switch

							layoutpolicy_horizontal = expanding
							layoutpolicy_vertical = expanding

							blockoverride "scrollbox_content"
							{
								layoutpolicy_horizontal = expanding
								layoutpolicy_vertical = expanding

								text_single = {
									name = "no_situations_text"
									visible = "[And( Not( SituationListWindow.HasAnyInvolvedSituationGroups ), PdxGuiTabs.IsTabSet( 'your' ) )]"
									layoutpolicy_horizontal = expanding
									layoutpolicy_vertical = expanding
									
									text = "SITUATION_LIST_NO_SITUATIONS"
									default_format = "#weak"
									align = center
								}

								vbox = {
									name = "situation_groups_container"
									margin_bottom = 8
									spacing = 15

									layoutpolicy_horizontal = expanding

									datamodel = "[SituationListWindow.GetSituationGroupItems]"

									item = {
										vbox_situation_group_foldout = {}
									}
								}
							}
						}
					}
				}

				expand = {}
			}
		}
	}
}

types SituationList
{
	type situation_tabs = hbox {
		name = "situation_tabs"
		layoutpolicy_horizontal = expanding

		button_tab = {
			name = "open_situations_tab"

			down = "[GetVariableSystem.HasValue( 'situations_tab', 'situations' )]"
			onclick = "[GetVariableSystem.Set( 'situations_tab', 'situations' )]"
			onclick = "[OpenGameView( 'situations' )]"
			shortcut = "tab_1"

			blockoverride "tab_label"
			{
				text = "SITUATION_LIST_WINDOW_HEADER"
				max_width = 130
			}

			blockoverride "icon_visible" {}

			blockoverride "tab_icon"
			{
				texture = "gfx/interface/icons/flat_icons/situation.dds"
			}
		}

		button_tab = {
			name = "open_legens_tab"

			down = "[GetVariableSystem.HasValue( 'situations_tab', 'legends' )]"
			onclick = "[GetVariableSystem.Set( 'situations_tab', 'legends' )]"
			onclick = "[OpenGameView( 'legends' )]"
			
			shortcut = "tab_2"

			blockoverride "tab_label"
			{
				text = "LEGENDS_TITLE"
				max_width = 130
			}

			blockoverride "icon_visible" {}

			blockoverride "tab_icon"
			{
				texture = "gfx/interface/icons/flat_icons/legends.dds"
				size = { 35 35 }
				position = { 0 2 }
			}
		}

		button_tab = {
			down = "[GetVariableSystem.HasValue( 'situations_tab', 'epidemics' )]"
			onclick = "[GetVariableSystem.Set( 'situations_tab', 'epidemics' )]"
			onclick = "[OpenGameView( 'epidemics' )]"
			shortcut = "tab_3"

			blockoverride "tab_label"
			{
				text = "EPIDEMICS_TITLE"
				max_width = 130
			}

			blockoverride "icon_visible" {}

			blockoverride "tab_icon"
			{
				size = { 35 35 }
				position = { 0 2 }
				texture = "gfx/interface/icons/flat_icons/epidemics.dds"

			}
		}
	}

	type vbox_situation_group_foldout = vbox {
		layoutpolicy_horizontal = expanding
		
		datacontext = "[SituationGroupItem.GetGroupType]"
		visible = "[And( Not( IsDataModelEmpty( SituationGroupItem.GetItems ) ), GreaterThan_int32( SituationGroupItem.GetNumInvolvedItems( PdxGuiTabs.IsTabSet( 'your' ) ), '(int32)0' ) )]"

		oncreate = "[BindFoldOutContext]"
		oncreate = "[PdxGuiFoldOut.Unfold]"

		button_expandable_toggle_field = {
			blockoverride "text"
			{
				text = "[SituationGroupItem.GetGroupTitle( PdxGuiTabs.IsTabSet( 'your' ) )]"
			}
		}

		vbox = {
			visible = "[PdxGuiFoldOut.IsUnfolded]"
			layoutpolicy_horizontal = expanding

			vbox = {
				layoutpolicy_horizontal = expanding
				spacing = 30
				
				datamodel = "[SituationGroupItem.GetItems]"
				item = {
					vbox_story_cycle_entry = {
						datacontext = "[SituationItem.GetStoryCycle]"
						visible = "[And( SituationItem.IsStoryCycle, Not( PdxGuiTabs.IsTabSet( 'other' ) ) )]"
					}
				}
			}
		}

		
		vbox = {
			visible = "[PdxGuiFoldOut.IsUnfolded]"
			layoutpolicy_horizontal = expanding

			dynamicgridbox = {
				name = "situations_in_group"
				layoutpolicy_horizontal = expanding
				
				datamodel = "[SituationGroupItem.GetItems]"

				item = {
					widget = {
						visible = "[Or( And( SituationItem.IsParticipant, PdxGuiTabs.IsTabSet( 'your' ) ), And( Not( SituationItem.IsParticipant ), PdxGuiTabs.IsTabSet( 'other' ) ) )]"
						minimumsize = { 527 100 }

						vbox_situation_entry = {
							datacontext = "[SituationItem.GetSituation]"
							visible = "[SituationItem.IsSituation]"
							margin_top = 5
						}

						vbox_struggle_entry = {
							datacontext = "[SituationItem.GetStruggle]"
							visible = "[SituationItem.IsStruggle]"
							margin_top = 5
						}
					}
				}
			}
		}
	}

	type button_open_situation = button_standard {
		layoutpolicy_horizontal = expanding
		size = { 0 60 }

		widget = {
			minimumsize = { 527 56 }
			position = { -2 2 }

			parentanchor = right|top
			scissor = yes

			proportional_icon = {
				name = "illustration"
				parentanchor = right|top
				size = { 250 100 }

				block "button_illustration"
				{
					texture = "gfx/interface/_debug/placeholder.dds"
				}

				alpha = 0.7
				mirror = horizontal

				modify_texture = {
					texture = "gfx/interface/component_masks/mask_fade_horizontal_extended.dds"
					blend_mode = alphamultiply
				}
			}
		}

		# Vignette
		margin_widget = {
			parentanchor = center
			size = { 100% 100% }

			margin = { 2 2 }

			icon = {
				parentanchor = center
				size = { 100% 100% }

				texture = "gfx/interface/component_tiles/tile_vignette_3px.dds"
				spriteType = Corneredtiled
				spriteborder = { 5 5 }
			}
		}

		hbox = {
			layoutpolicy_vertical = expanding
			layoutpolicy_horizontal = expanding

			margin = { 10 0 }
			spacing = 10

			highlight_icon = {
				size = { 40 40 }

				block "button_icon"
				{
					texture = "gfx/interface/_debug/icon_placeholder_02.dds"
				}
			}

			block "button_text"
			{
				text_single = {
					raw_text = "button_text"
					align = nobaseline
				}
			}

			expand = {}
		}
	}

	type vbox_situation_entry = vbox {
		layoutpolicy_horizontal = expanding

		hbox = {
			layoutpolicy_horizontal = expanding

			spacing = 8

			button_open_situation = {
				datacontext = "[GetPlayer]"
				layoutpolicy_horizontal = expanding

				onclick = "[ToggleGameViewData( Situation.GetWindowName, Situation.GetID )]"

				tooltipwidget = {
					using = situation_tooltip
				}

				blockoverride "button_illustration"
				{
					texture = "[Situation.GetType.GetIllustration]"
				}

				blockoverride "button_icon"
				{
					texture = "[Situation.GetIcon]"
				}

				blockoverride "button_text"
				{
					text_single = {
						text = "[Situation.GetNameNoTooltip]"
						align = nobaseline
					}
				}
			}

			button_situation_visibility_toggle = { }
		}

		block "current_phase_block" {
			vbox = {
				margin_left = 10
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding

				background = {
					using = Background_Area_Characterlist

					modify_texture = {
						texture = "gfx/interface/component_masks/mask_fade_horizontal_extended.dds"
						blend_mode = alphamultiply
					}
				}

				text_single = {
					layoutpolicy_horizontal = expanding
					autoresize = no


					text = "SITUATION_LIST_SITUATION_PHASE"
					align = nobaseline
				}
			}
		}
	}

	type vbox_struggle_entry = vbox {
		minimumsize = { 527 100 }
		layoutpolicy_horizontal = expanding

		hbox = {
			layoutpolicy_horizontal = expanding

			spacing = 8

			button_open_situation = {
				datacontext = "[GetPlayer]"

				onclick = "[ToggleGameViewData( 'struggle', Struggle.GetID )]"

				tooltipwidget = {
					using = struggle_tooltip
				}

				blockoverride "button_illustration"
				{
					texture = "[Struggle.GetType.GetIllustration]"
				}

				blockoverride "button_icon"
				{
					texture = "[Struggle.GetCurrentPhase.GetIcon]"
				}

				blockoverride "button_text"
				{
					text_single = {
						text = "[Struggle.GetNameNoTooltip]"
						align = nobaseline
					}
				}
			}

			button_situation_visibility_toggle = {

				# adapt to struggle via blockoverrides

				blockoverride "visibility_toggled_base"
				{
					down = "[IsStrugglePriority( Struggle.Self, 'visible' )]"
					tooltip = "STRUGGLE_TOGGLE_VISIBLE_BUTTON_TT"
				}

				blockoverride "visibility_toggled_on"
				{
					visible = "[IsStrugglePriority( Struggle.Self, 'visible' )]"
					onclick = "[PostCommand( PinStruggle( Struggle.Self, 'hidden') )]"
				}

				blockoverride "visibility_toggled_off"
				{
					visible = "[IsStrugglePriority( Struggle.Self, 'hidden' )]"
					onclick = "[PostCommand( PinStruggle( Struggle.Self, 'visible' ) )]"
				}
			}
		}

		vbox = {
			margin_left = 10
			layoutpolicy_horizontal = expanding
			layoutpolicy_vertical = expanding

			background = {
				using = Background_Area_Characterlist

				modify_texture = {
					texture = "gfx/interface/component_masks/mask_fade_horizontal_extended.dds"
					blend_mode = alphamultiply
				}
			}

			text_single = {
				layoutpolicy_horizontal = expanding

				text = "SITUATION_LIST_STRUGGLE_PHASE"
				align = nobaseline
			}
		}
	}

	type button_situation_visibility_toggle = button_round {
		size = { 40 40 }

		block "visibility_toggled_base"
		{
			down = "[IsSituationPriority( Situation.Self, 'visible' )]"
			tooltip = "SITUATION_TOGGLE_VISIBLE_BUTTON_TT"
		}

		using = tooltip_sw


		button = {
			name = "is_shown"
			size = { 100%  100% }

			block "visibility_toggled_on"
			{
				visible = "[IsSituationPriority( Situation.Self, 'visible' )]"
				onclick = "[PostCommand( PinSituation( Situation.Self, 'hidden') )]"
			}

			highlight_icon = {
				texture = "gfx/interface/icons/flat_icons/observer.dds"
				parentanchor = center
				size = { 30 30 }
				using = Master_Button_Modify_Texture
			}
		}

		button = {
			name = "is_hidden"
			size = { 100%  100% }

			block "visibility_toggled_off"
			{
				visible = "[IsSituationPriority( Situation.Self, 'hidden' )]"
				onclick = "[PostCommand( PinSituation( Situation.Self, 'visible' ) )]"
			}

			highlight_icon = {
				texture = "gfx/interface/icons/flat_icons/hide_ui.dds"
				parentanchor = center
				size = { 30 30 }
				using = Master_Button_Modify_Texture
			}
		}
	}

	type vbox_story_cycle_entry = vbox {
		layoutpolicy_horizontal = expanding
		margin = { 12 5 }
		margin_bottom = 10

		background = {
			using = Background_Frame
			margin_bottom = 10
			margin_left = 1
		}

		background = {
			parentanchor = center
			using = Mask_Rough_Edges
			texture = "[Story.GetBackground]"
			alpha = 0.10
			fittype = centercrop
			margin_bottom = 10
		}

		# Basic Info
		hbox = {
			layoutpolicy_horizontal = expanding
			margin_left = -5

			# Icon
			icon_story_cycle = {}

			# Title and Desc
			vbox = {
				layoutpolicy_horizontal = expanding

				text_single = {
					layoutpolicy_horizontal = expanding
					text = "SITUATION_LIST_STORY_CYCLE_ENTRY_TITLE"
					align = nobaseline
					max_width = 345
					using = Font_Size_Big
					default_format = "#T"
				}

				text_multi = {
					layoutpolicy_horizontal = expanding
					margin_right = 10
					multiline = yes
					text = "SITUATION_LIST_STORY_CYCLE_ENTRY_DESC"
					align = left
					default_format = "#flavor;italic"
					autoresize = yes
					max_width = 345
				}
			}
		}

		### Modules

		# Custom String Key
		vbox = {
			visible = "[Story.HasCustomString]"
			layoutpolicy_horizontal = expanding
			margin = { 10 10 }

			text_multi = {
				layoutpolicy_horizontal = expanding
				multiline = yes
				text = "[Story.GetCustomString]"
				align = left
				autoresize = yes
				max_width = 480
			}
		}

		# Modifiers
		vbox = {
			layoutpolicy_horizontal = expanding
			margin = { 20 5 }
			spacing = 10

			visible = "[Story.HasModifiers]"

			hbox = {
				layoutpolicy_vertical = expanding
				layoutpolicy_horizontal = expanding

				flowcontainer = {
					datamodel = "[Story.GetModifiers]"
					direction = horizontal
					max_width = 500
					ignoreinvisible = yes

					item = {
						icon = {
							visible = "[Story.GetOwner.HasStaticModifier( StaticModifier.Self )]"

							size = { 32 32 }
							alwaystransparent = no
							texture = "[StaticModifier.GetIcon]"

							tooltipwidget = {
								object_tooltip_pop_out = {
									blockoverride "header_additions" {
										hbox = {
											margin_right = 10
											margin_top = 8
											margin_left = -4

											icon = {
												size = { 32 32 }
												texture = "[StaticModifier.GetIcon]"
												tintcolor = "[TooltipInfo.GetTintColor]"
											}
										}
									}

									blockoverride "title_text" {
										margin = { 0 8 }
										text = "[StaticModifier.GetName]"
									}

									blockoverride "concept_link" {
										text = ""
									}

									blockoverride "main_description" {
										vbox = {
											layoutpolicy_horizontal = expanding
											layoutpolicy_vertical = expanding

											text_multi = {
												autoresize = yes
												max_width = 350
												text = "[StaticModifier.GetDescWithEffects]"
											}
										}
									}
								}
							}
						}
					}
				}

				expand = {}
			}
		}

		# Progress Bars
		vbox = {
			name = "progress_bars_grid"
			visible = "[Story.HasBasicCounters]"
			datamodel = "[Story.GetBasicCounters]"
			layoutpolicy_horizontal = expanding

			item = {
				vbox = {
					visible = "[Story.MakeScope.HasFlag(StoryCycleCounterVisualization.GetVariableName)]"
					layoutpolicy_horizontal = expanding
					min_width = 500

					background = { using = Background_Story }

					text_single = {
						layoutpolicy_horizontal = expanding
						text = "[StoryCycleCounterVisualization.GetLabel]"
						using = Font_Size_Medium
						margin_top = 2
						margin_left = 10
						layoutpolicy_vertical = expanding
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						min_width = 500
						margin = { 10 10 }
						spacing = 25

						expand = {}

						text_single = {
							text = "[StoryCycleCounterVisualization.GetMinLabel]"
							align = nobaseline
						}

						progressbar_standard = {
							layoutpolicy_horizontal = expanding
							size = { 1 30 }

							min = "[StoryCycleCounterVisualization.GetMinValue]"
							max = "[StoryCycleCounterVisualization.GetMaxValue]"
							animated_progress_value = "[Story.MakeScope.Var( StoryCycleCounterVisualization.GetVariableName ).GetValue]"

							tooltip = "[StoryCycleCounterVisualization.GetTooltip( Story.Self )]"
							using = tooltip_se

							using = Animation_ShowHide_Standard

							marker = {
								name = "current_value"

								widget_level_marker_no_anchor = {
									scale = 0.8
									text_single = {
										parentanchor = center
										text = "[Story.MakeScope.Var( StoryCycleCounterVisualization.GetVariableName ).GetValue]"
										default_format = "#high"
										align = nobaseline
									}
								}
							}
						}

						text_single = {
							text = "[StoryCycleCounterVisualization.GetMaxLabel]"
							align = nobaseline
						}

						expand = {}
					}
				}
			}
		}

		# Tug of War
		vbox = {
			name = "tug_of_war_grid"
			visible = "[Story.HasTugOfWarCounters]"
			datamodel = "[Story.GetTugOfWarCounters]"
			layoutpolicy_horizontal = expanding

			item = {
				vbox = {
					visible = "[Story.MakeScope.HasFlag(StoryCycleCounterVisualization.GetVariableName)]"
					layoutpolicy_horizontal = expanding
					min_width = 500

					background = { using = Background_Story }

					text_single = {
						layoutpolicy_horizontal = expanding
						text = "[StoryCycleCounterVisualization.GetLabel]"
						using = Font_Size_Medium
						margin_top = 2
						margin_left = 10
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						min_width = 500
						margin = { 10 10 }
						spacing = 25

						expand = {}

						text_single = {
							text = "[StoryCycleCounterVisualization.GetMinLabel]"
							align = nobaseline
						}

						progressbar_standard = {
							layoutpolicy_horizontal = expanding
							size = { 0 30 }

							noprogresstexture = "gfx/interface/progressbars/progress_grandeur_decrease.dds"
							progresstexture = "gfx/interface/progressbars/progress_grandeur_increase.dds"

							min = "[StoryCycleCounterVisualization.GetMinValue]"
							max = "[StoryCycleCounterVisualization.GetMaxValue]"
							animated_progress_value = "[Story.MakeScope.Var( StoryCycleCounterVisualization.GetVariableName ).GetValue]"

							tooltip = "[StoryCycleCounterVisualization.GetTooltip( Story.Self )]"
							using = tooltip_se

							using = Animation_ShowHide_Standard

							marker = {
								name = "current_value"

								widget_level_marker_no_anchor = {
									scale = 0.8
									text_single = {
										parentanchor = center
										text = "[Story.MakeScope.Var( StoryCycleCounterVisualization.GetVariableName ).GetValue]"
										default_format = "#high"
										align = nobaseline
									}
								}
							}
						}

						text_single = {
							text = "[StoryCycleCounterVisualization.GetMaxLabel]"
							align = nobaseline
						}

						expand = {}
					}
				}
			}
		}

		# Traits
		vbox = {
			name = "traits"
			visible = "[Story.HasTraits]"
			datamodel = "[Story.GetTraits]"
			datacontext = "[Story.GetOwner]"
			layoutpolicy_horizontal = expanding
			margin = { 0 10 }
			spacing = 10

			item = {
				vbox = {
					visible = "[Trait.IsValid]"
					layoutpolicy_horizontal = expanding
					min_width = 500

					background = {
						using = Background_Story
						margin_bottom = 10
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						margin_left = 10

						trait_icon_texture = {}

						text_single = {
							layoutpolicy_horizontal = expanding
							text = "[Trait.GetNameNoTooltipWithDefault( Character.Self )]"
							using = Font_Size_Medium
							margin_left = 5
							margin_top = -15
						}

						expand = {}
					}

					text_multi = {
						layoutpolicy_horizontal = expanding
						multiline = yes
						text = "[Trait.GetFullDescription( Character.Self, Character.GetFaith.Self )]"
						align = left
						autoresize = yes
						max_width = 480
						margin = { 0 0 }
					}

					vbox = {
						name = "trait_level_tracks"
						layoutpolicy_horizontal = expanding
						visible = "[DataModelHasItems( Trait.GetLevelTracks )]"
						max_width = 480

						spacer = {
							size = { 10 10 }
						}

						text_label_left = {
							layoutpolicy_horizontal = expanding
							text = "TRAIT_LEVEL_TRACKS_HEADER"
						}

						vbox = {
							layoutpolicy_horizontal = expanding
							datamodel = "[Trait.GetLevelTracks]"
							spacing = 5
							allow_outside = yes

							item = {
								hbox = {
									layoutpolicy_horizontal = expanding
									allow_outside = yes
									spacing = 5
									margin_right = 20

									vbox = {
										margin_top = 6

										icon = {
											size = { 30 30 }
											texture = "[TraitLevelTrack.GetIcon( Trait.Self, Character.Self )]"
										}
									}

									vbox = {
										layoutpolicy_horizontal = expanding
										spacing = 5

										text_single = {
											layoutpolicy_horizontal = expanding
											text = "[TraitLevelTrack.GetName]"
										}

										widget = {
											size = { 0 15 }
											layoutpolicy_horizontal = expanding
											allow_outside = yes

											datacontext = "[Character.GetTraitTrackProgressBar( Trait.Self, TraitLevelTrack.Self )]"

											hbox_complex_bar_progress_next = {
												size = { 0 15 }
												layoutpolicy_horizontal = expanding
												tooltip = "TRAIT_LEVEL_TRACK_PROGRESS_TOOTLIP"
												using = tooltip_se
											}

											hbox_complex_bar_levels = {
												size = { 0 15 }
												layoutpolicy_horizontal = expanding

												blockoverride "marker"
												{
													widget_level_marker = {
														scale = 0.75
														datacontext = "[TraitLevelTrack.GetEntryForXp( ComplexBarItem.GetValue )]"
														visible = "[GreaterThanOrEqualTo_int32( TraitLevelTrackEntry.GetLevel, '(int32)0' )]"

														blockoverride "visible_active"
														{
															visible = "[EqualTo_int32( Character.GetTraitTrackLevel( Trait.Self, TraitLevelTrack.Self ), TraitLevelTrackEntry.GetLevel )]"
														}

														blockoverride "visible_inactive"
														{
															visible = "[Not( EqualTo_int32( Character.GetTraitTrackLevel( Trait.Self, TraitLevelTrack.Self ), TraitLevelTrackEntry.GetLevel ) )]"
														}

														blockoverride "marker_tooltip"
														{
															tooltip = "TRAIT_LEVEL_TRACK_TT"
															using = tooltip_se
														}

														blockoverride "marker_text"
														{
															text = "[TraitLevelTrackEntry.GetLevel]"
														}
													}
												}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}

		# Specific Characters
		vbox = {
			name = "characters_grid"
			visible = "[Story.HasSpecificCharacters]"
			datamodel = "[Story.GetSpecificCharacters]"
			layoutpolicy_horizontal = expanding

			item = {
				vbox = {
					min_width = 500
					visible = "[Story.MakeScope.HasFlag(StoryCycleVariableVisualization.GetVariableName)]"
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding
					margin = { 4 0 }

					background = { using = Background_Story }

					text_single = {
						layoutpolicy_horizontal = expanding
						text = "[StoryCycleVariableVisualization.GetLabel]"
						using = Font_Size_Medium
						margin_top = 2
						margin_bottom = 5
						margin_left = 6
					}

					widget_story_character_item = {
						datacontext = "[Story.MakeScope.Var( StoryCycleVariableVisualization.GetVariableName ).Char]"
						layoutpolicy_horizontal = expanding

						blockoverride "description_relation_text" {
							text = "[SelectLocalization(Character.IsGuest, Character.GetRelationAndGuestDesc, Character.GetRelationToString(GetPlayer.Self))]"
							tooltip = "EXTENDED_RELATIONS_TOOLTIP"
						}
					}
				}
			}
		}

		# Lists of Characters
		vbox = {
			name = "character_lists_grid"
			visible = "[Story.HasCharacterLists]"
			datamodel = "[Story.GetCharacterLists]"
			layoutpolicy_horizontal = expanding

			item = {
				vbox = {
					visible = "[Not(IsDataModelEmpty(Story.MakeScope.GetList(StoryCycleVariableVisualization.GetVariableName)))]"
					layoutpolicy_horizontal = expanding
					min_width = 500
					margin_bottom = 10

					background = { using = Background_Story }

					text_single = {
						layoutpolicy_horizontal = expanding
						text = "[StoryCycleVariableVisualization.GetLabel]"
						using = Font_Size_Medium
						margin_top = 2
						margin_bottom = 5
						margin_left = 10
					}

					spacer = { size = { 0 5 } }

					fixedgridbox = {
						datamodel = "[Story.MakeScope.GetList( StoryCycleVariableVisualization.GetVariableName )]"
						addcolumn = 80
						addrow = 90
						flipdirection = yes
						datamodel_wrap = 6

						item = {
							portrait_head_small = {
								datacontext = "[Scope.Char]"
							}
						}
					}
				}
			}
		}

		# Specific Titles
		vbox = {
			name = "titles_grid"
			visible = "[Story.HasSpecificTitles]"
			datamodel = "[Story.GetSpecificTitles]"
			layoutpolicy_horizontal = expanding

			item = {
				hbox = {
					datacontext = "[Story.MakeScope.Var( StoryCycleVariableVisualization.GetVariableName ).Title]"
					visible = "[Story.MakeScope.HasFlag( StoryCycleVariableVisualization.GetVariableName )]"
					
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding
					
					min_width = 500
					margin_bottom = 10					

					coa_title_medium_crown = {}

					vbox = {
						layoutpolicy_horizontal = expanding

						background = {
							using = Background_Story
							margin = { 4 35 }
							margin_left = 2
						}

						text_single = {
							layoutpolicy_horizontal = expanding
							text = "[StoryCycleVariableVisualization.GetLabel]"
							using = Font_Size_Medium
							margin_top = -43
							margin_left = 10
						}

						text_single = {
							layoutpolicy_horizontal = expanding
							text = "[Title.GetName]"
							using = Font_Size_Medium
							margin_top = 5
							margin_left = 10
						}
					}
				}
			}
		}

		# Lists of Titles
		vbox = {
			name = "title_lists_grid"
			visible = "[Story.HasTitleLists]"
			datamodel = "[Story.GetTitleLists]"
			layoutpolicy_horizontal = expanding
			margin_top = -10

			item = {
				vbox = {
					visible = "[Not(IsDataModelEmpty(Story.MakeScope.GetList(StoryCycleVariableVisualization.GetVariableName)))]"
					layoutpolicy_horizontal = expanding
					min_width = 500
					margin_left = 10

					background = { using = Background_Story }

					text_single = {
						layoutpolicy_horizontal = expanding
						text = "[StoryCycleVariableVisualization.GetLabel]"
						using = Font_Size_Medium
						margin_top = 2
						margin_left = 20
					}

					spacer = { size = { 0 10 } }

					fixedgridbox = {
						datamodel = "[Story.MakeScope.GetList( StoryCycleVariableVisualization.GetVariableName )]"
						addcolumn = 85
						addrow = 90
						flipdirection = yes
						datamodel_wrap = 5

						item = {
							coa_title_medium = {
								datacontext = "[Scope.Title]"
							}
						}
					}
				}
			}
		}

		# Specific Artifacts
		vbox = {
			name = "artifacts_grid"
			visible = "[Story.HasSpecificArtifacts]"
			datamodel = "[Story.GetSpecificArtifacts]"
			layoutpolicy_horizontal = expanding

			item = {
				vbox = {
					min_width = 500
					visible = "[Story.MakeScope.HasFlag(StoryCycleVariableVisualization.GetVariableName)]"
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding

					background = { using = Background_Story }

					text_single = {
						layoutpolicy_horizontal = expanding
						text = "[StoryCycleVariableVisualization.GetLabel]"
						using = Font_Size_Medium
						margin_top = 2
						margin_left = 10
					}

					hbox = {
						datacontext = "[Story.MakeScope.Var(StoryCycleVariableVisualization.GetVariableName).Artifact]"
						layoutpolicy_horizontal = expanding

						tooltipwidget = {
							artifact_tooltip = {}
						}

						vbox = {
							name = "icon"
							layoutpolicy_vertical = expanding
							margin = { 2 2 }

							icon_artifact = {
								blockoverride "tooltipwidget" {}
							}
						}

						vbox = {
							name = "text"
							layoutpolicy_vertical = expanding
							margin_top = 4
							margin_bottom = 10

							expand = {}

							text_single = {
								layoutpolicy_horizontal = expanding
								text = "[Artifact.GetRarityAndSlotType]"
								max_width = 350
								using = Font_Size_Small
							}

							text_multi = {
								layoutpolicy_horizontal = expanding
								text = "[Artifact.GetNameNoTooltip]"
								autoresize = yes
								max_width = 350
								using = Font_Size_Medium
								default_format = "#high"
								alwaystransparent = yes
							}

							spacer = {
								size = { 0 6 }
							}

							hbox_artifact_durability = {
								layoutpolicy_horizontal = expanding
								# simple tooltip override so that the durability tooltip doesnt show up here
								tooltip = ""
							}

							expand = {}
						}

						expand = {}
					}
				}
			}
		}

		# Lists of Artifacts
		vbox = {
			name = "artifact_lists_grid"
			visible = "[Story.HasArtifactLists]"
			datamodel = "[Story.GetArtifactLists]"
			layoutpolicy_horizontal = expanding

			item = {
				vbox = {
					visible = "[Not(IsDataModelEmpty(Story.MakeScope.GetList(StoryCycleVariableVisualization.GetVariableName)))]"
					layoutpolicy_horizontal = expanding
					min_width = 500

					background = { using = Background_Story }

					text_single = {
						layoutpolicy_horizontal = expanding
						text = "[StoryCycleVariableVisualization.GetLabel]"
						using = Font_Size_Medium
						margin_top = 2
						margin_left = 10
					}

					spacer = { size = { 0 5 } }

					fixedgridbox = {
						datamodel = "[Story.MakeScope.GetList( StoryCycleVariableVisualization.GetVariableName )]"
						addcolumn = 85
						addrow = 90
						flipdirection = yes
						datamodel_wrap = 5

						item = {
							icon_artifact = {
								datacontext = "[Scope.Artifact]"
							}
						}
					}
				}
			}
		}

		# Decisions
		vbox = {
			layoutpolicy_horizontal = expanding
			spacing = 10
			margin_top = 10

			visible = "[Story.HasDecisions]"

			flowcontainer = {
				datamodel = "[Story.GetDecisions]"
				direction = vertical
				max_width = 500
				ignoreinvisible = yes

				item = {
					button_decision_entry = {
						name = "story_decision_entry"
						visible = "[Decision.IsShownForPlayer]"
						size = { 493 45 }
						using = tooltip_se

						onclick = "[OpenGameViewData( 'decision_detail', Decision.Self)]"
					}
				}
			}
		}
	}

	type icon_story_cycle = icon {
        size = { 140 140 }

        background = {
            texture = "gfx/interface/window_situations/story_icon_background_01.dds"
            color = { 0.3 0.4 0.48 0.75 } ### WE COULD SET UP COLOR CHANGES HERE ###
			alpha = 0.75
        }
        icon = {
            name = "story_icon"
            size = { 100% 100% }
            parentanchor = center
            texture = "[Story.GetIcon]"
        }
    }

	type widget_story_character_item = widget {
		size = { 100 125 }

		hbox = {
			spacing = 5

			background = {
				using = Background_Area_With_Header
				margin_right = 7
				margin_left = 5
			}

			portrait_head = {}

			vbox = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				margin_top = 3

				hbox = {
					layoutpolicy_horizontal = expanding

					text_single = {
						name = "name"
						layoutpolicy_horizontal = expanding
						autoresize = no
						text = "[Character.GetUINameNoTooltip]"
						using = Font_Size_Medium
						align = nobaseline
						fontsize_min = 14
						margin_right = 10
					}

					#hbox_skills_grid = {}
				}

				vbox = {
					layoutpolicy_horizontal = expanding
					margin = { 0 3 }
					margin_bottom = 8

					hbox = {
						layoutpolicy_horizontal = expanding
						spacing = 3

						warning_icon = {
							visible = "[And( Character.CourtierWantsToLeaveCourt, Not( Character.IsImprisoned))]"
							size = { 20 20 }
							tooltip = "[Character.GetCourtierLeaveDescription]"
						}

						debug_square = {
							visible = "[AIWatchWindowsEnabled]"
							size = { 20 20 }
							raw_tooltip = "#D [Character.GetDebugCourtierLeaveReasons]#!"
						}

						text_single = {
							name = "relation_to_court_owner"
							default_format = "#low"
							align = nobaseline
							max_width = 370
							visible = "[Not(Character.IsHostage)]"

							block "description_relation_text" {
								text = "[Character.GetRelationToString( Story.GetOwner )]"
								tooltip = "EXTENDED_RELATIONS_TOOLTIP"
							}

							background = {
								visible = "[Character.IsImprisoned]"
								using = Status_Bad
								alpha = 0.5
							}
						}

						text_single = {
							name = "relation_to_court_hostage"
							default_format = "#medium"
							align = nobaseline
							visible = "[Character.IsHostage]"

							block "description_relation_text" {
								text = "[Character.GetRelationToString( Story.GetOwner )]"
								tooltip = "EXTENDED_RELATIONS_TOOLTIP"
							}

							background = {
								visible = "[Character.IsHostage]"
								using = Status_Mixed
								alpha = 0.5
							}
						}
						expand = {}

						text_single = {
							name = "has_guardian"
							default_format = "#low"
							align = nobaseline
							max_width = 370
							margin_right = 5
							visible = "[And( Not(Character.IsAdult), Not(Character.HasGuardian) )]"

							text = "COURT_WINDOW_NO_GUARDIAN"
							tooltip = "COURT_WINDOW_NO_GUARDIAN_TOOLTIP"
						}
					}
				}

				hbox = {
					layoutpolicy_horizontal = expanding
					spacing = 5
					margin_bottom = 5

					hbox = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding
						minimumsize = { 0 60 }
						margin_left = 5

						background = {
							using = Background_Area_Dark
							margin = { 3 3 }
							alpha = 0.5
						}

						# Dynasty
						widget = {
							layoutpolicy_vertical = expanding
							size = { 45 40 }

							coa_house_small = {
								datacontext = "[Character.GetHouse]"
								parentanchor = center
								scale = 0.7
							}
						}

						# Traits
						vbox = {
							layoutpolicy_vertical = expanding
							margin = { 10 0 }

							hbox = {
								layoutpolicy_horizontal = expanding

								fixedgridbox = {
									name = "traits_grid_five"
									datamodel = "[Character.GetTraitsForCharacter]"
									flipdirection = yes
									addcolumn = 30
									addrow = 28

									datamodel_wrap = 5
									maxverticalslots = 2

									item = {
										icon_trait = {
											visible = "[Trait.IsValid]"

											blockoverride "icon_size"
											{
												size = { 30 30 }
											}

											blockoverride "tooltip_placement"
											{
												using = tooltip_se
											}

											blockoverride "glow_radius"
											{
												glow_radius = 3
											}
										}
									}
								}

								expand = {}
							}
						}

						expand = {}

						divider_light = {
							layoutpolicy_vertical = expanding
							alpha = 0.5
						}

						hbox = {
							margin_right = 5

							button_religion_icon = {
								datacontext = "[Character.GetFaith]"
								size = { 40 40 }
							}

							vbox = {
								datacontext = "[Character.GetCulture]"

								tooltipwidget = {
									culture_tooltip = {}
								}
								using = tooltip_se

								icon = {
									name = "culture"
									texture = "gfx/interface/icons/icon_culture.dds"
									size = { 24 24 }
								}

								text_single = {
									layoutpolicy_horizontal = expanding
									min_width = 60
									align = center|nobaseline
									autoresize = no
									text = "CULTURE_LISTS_WINDOW"
								}
							}
						}
					}
				}
			}
		}
	}
}

template "Background_Story" {
	using = Background_Area_With_Header
	using = Mask_Rough_Edges
	margin = { 4 0 }
}
